{
  "name": "live-cursors",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build:embed": "esbuild src/client/embed.ts --bundle --minify --outfile=public/embed.js --format=iife --target=es2018",
    "build:wc": "esbuild src/client/embed-wc.ts --bundle --minify --outfile=public/embed-wc.js --format=iife --target=es2018",
    "build": "npm run build:embed && npm run build:wc",
    "deploy": "npm run build && wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
